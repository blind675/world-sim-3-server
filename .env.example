PORT=4000
CORS_ORIGIN=http://localhost:3000,https://terraria-sim.netlify.app

# World generation
WORLD_SEED=20260420
WORLD_WIDTH=5120
WORLD_HEIGHT=5120
WORLD_CELL_SIZE=1
WORLD_CHUNK_SIZE=128

# Terrain height range (meters)
TERRAIN_MIN_HEIGHT=-10
TERRAIN_MAX_HEIGHT=80

# Simulation
SIM_TICK_MS=200

# Perception (Milestone 4)
VISION_CONE_DEG=100
VISION_NEAR_RADIUS=4
MEMORY_DECAY_FLOOR=0.02

# Memory clustering (Milestone 4 extension)
# Max pairwise cell distance for same-type memories to be grouped.
MEMORY_CLUSTER_RADIUS=4
# Minimum number of individuals required to collapse into a cluster.
MEMORY_CLUSTER_MIN_COUNT=3
# How many times slower clusters decay vs individuals (100 = near-permanent).
MEMORY_CLUSTER_DECAY_MULT=100
